{
  "name": "open-geo-console",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "worker": "npm run worker --workspace apps/web",
    "worker:free": "npm run worker:free --workspace apps/web",
    "worker:deep": "npm run worker:deep --workspace apps/web",
    "worker:drain:free": "npm run worker:drain:free --workspace apps/web",
    "worker:drain:deep": "npm run worker:drain:deep --workspace apps/web",
    "worker:realtime:free": "npm run worker:realtime:free --workspace apps/web",
    "worker:realtime:deep": "npm run worker:realtime:deep --workspace apps/web",
    "worker:staging:free": "npm run worker:staging:free --workspace apps/web",
    "worker:staging:deep": "npm run worker:staging:deep --workspace apps/web",
    "queue:dispatch": "npm run queue:dispatch --workspace apps/web",
    "queue:reconcile": "npm run queue:reconcile --workspace apps/web",
    "commerce:email": "npm run commerce:email --workspace apps/web",
    "commerce:refunds": "npm run commerce:refunds --workspace apps/web",
    "commerce:sla": "npm run commerce:sla --workspace apps/web",
    "commerce:reconcile": "npm run commerce:reconcile --workspace apps/web",
    "commerce:all": "npm run commerce:all --workspace apps/web",
    "commerce:retire-legacy": "npm run commerce:retire-legacy --workspace apps/web",
    "commerce:staging:all": "npm run commerce:staging:all --workspace apps/web",
    "browser:install": "npm run browser:install --workspace apps/web",
    "access-key:create": "npm run access-key:create --workspace apps/web --",
    "ai:probe": "npm run ai:probe --workspace apps/web",
    "test:ai-live": "npm run test:ai-live --workspace apps/web",
    "db:audit": "npm run db:audit --workspace apps/web",
    "db:environment:init": "npm run db:environment:init --workspace apps/web --",
    "db:environment:inspect": "npm run db:environment:inspect --workspace apps/web",
    "staging:free:cleanup": "npm run staging:free:cleanup --workspace apps/web --",
    "test:postgres:staging-security": "npm run test:postgres:staging-security --workspace apps/web",
    "db:migrate:sqlite": "npm run db:migrate:sqlite --workspace apps/web --",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace apps/web",
    "test": "vitest run",
    "codegraph:init": "codegraph init -i"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

{
  "name": "open-geo-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "worker": "npm run worker --workspace apps/web",
    "worker:free": "npm run worker:free --workspace apps/web",
    "worker:deep": "npm run worker:deep --workspace apps/web",
    "browser:install": "npm run browser:install --workspace apps/web",
    "access-key:create": "npm run access-key:create --workspace apps/web --",
    "ai:probe": "npm run ai:probe --workspace apps/web",
    "test:ai-live": "npm run test:ai-live --workspace apps/web",
    "db:migrate:sqlite": "npm run db:migrate:sqlite --workspace apps/web --",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace apps/web",
    "test": "vitest run",
    "codegraph:init": "codegraph init -i"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

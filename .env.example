DATABASE_URL=postgres://open_geo:open_geo@localhost:5432/open_geo_console
OGC_DATABASE_POOL_SIZE=10
# Required in every deployed process and must match the immutable marker in
# the connected PostgreSQL database. Use the local db:environment:init command once.
OGC_DEPLOYMENT_PROFILE=production
# Only VERCEL_ENV=preview plus profile=staging honors this value (maximum 100).
OGC_STAGING_FREE_SITE_LIMIT=100

# OpenAI-compatible endpoint. Never commit a real API key.
OGC_AI_BASE_URL=https://provider.example/v1
OGC_AI_API_KEY=replace-with-a-rotated-key
OGC_AI_MODEL=replace-with-the-provider-model-id
OGC_AI_JSON_RESPONSE_FORMAT=false
OGC_AI_TIMEOUT_MS=180000
OGC_LIVE_TEST_URL=https://company.com
OGC_LIVE_TEST_LOCALE=en

# Recommendation-forensics remains closed unless the runtime flag, a matching
# immutable DB authority, two exact provider surfaces, and the lane flag agree.
OGC_RECOMMENDATION_RUNTIME_ENABLED=false
OGC_RECOMMENDATION_OPERATOR_ENABLED=false
OGC_RECOMMENDATION_PUBLIC_ENABLED=false
OGC_RECOMMENDATION_REGION=global
OGC_RECOMMENDATION_CERTIFICATION_AUTHORITY_JSON=
OGC_SOURCE_CLASSIFICATION_AUTHORITY_JSON=
# Independent protected-staging artifact authenticity boundary. Keep this
# separate from model, token-hash, payment, and access-token secrets.
OGC_RECOMMENDATION_CERTIFICATION_SIGNING_SECRET=
OGC_RECOMMENDATION_CERTIFICATION_SIGNING_KEY_ID=
OGC_RECOMMENDATION_CERTIFICATION_SIGNING_VERSION=v1
OGC_ANSWER_OPENAI_API_KEY=
OGC_ANSWER_OPENAI_MODEL=
OGC_ANSWER_OPENAI_LOCALE=
OGC_ANSWER_OPENAI_REGION=
OGC_ANSWER_OPENAI_MAX_REQUESTS=5
OGC_ANSWER_OPENAI_MAX_COST_MICROS=5000000
OGC_ANSWER_OPENAI_TIMEOUT_MS=60000
OGC_ANSWER_OPENAI_MAX_TRANSIENT_RETRIES=1
OGC_ANSWER_PERPLEXITY_API_KEY=
OGC_ANSWER_PERPLEXITY_MODEL=
OGC_ANSWER_PERPLEXITY_LOCALE=
OGC_ANSWER_PERPLEXITY_REGION=
OGC_ANSWER_PERPLEXITY_MAX_REQUESTS=5
OGC_ANSWER_PERPLEXITY_MAX_COST_MICROS=5000000
OGC_ANSWER_PERPLEXITY_TIMEOUT_MS=60000
OGC_ANSWER_PERPLEXITY_MAX_TRANSIENT_RETRIES=1

# Provider-neutral public-source forensics budgets. No live search credential or vendor is configured here.
OGC_PUBLIC_SEARCH_DAILY_REQUEST_CAP=100
OGC_PUBLIC_SEARCH_DAILY_COST_MICROS_CAP=10000000
OGC_PUBLIC_SEARCH_MAX_RESULTS_PER_QUESTION=10
OGC_PUBLIC_SEARCH_TIMEOUT_MS=20000
OGC_PUBLIC_SOURCE_FETCH_MAX_BYTES=2097152
OGC_PUBLIC_SOURCE_FETCH_MAX_REDIRECTS=5

# Generate independent random values of at least 32 bytes for production.
OGC_TOKEN_HASH_SECRET=replace-with-a-long-random-secret
OGC_IP_HASH_SECRET=replace-with-a-different-long-random-secret

OGC_REPORT_BASE_URL=http://localhost:3000
OGC_WORKER_POLL_MS=5000
# Do not set OGC_WORKER_TIER globally when running both lanes. The
# worker:free and worker:deep scripts set it per process.
OGC_BROWSER_HEADLESS=true
# Private visual evidence bytes. Local development may use filesystem; every
# staging/production Web and deep Worker process must share one private object store.
# Use vercel-blob for a connected Vercel Private Blob store, or s3 for an S3-compatible private bucket.
OGC_EVIDENCE_STORAGE=vercel-blob
OGC_EVIDENCE_FILESYSTEM_ROOT=
OGC_EVIDENCE_S3_ENDPOINT=https://s3.example.com
OGC_EVIDENCE_S3_REGION=auto
OGC_EVIDENCE_S3_BUCKET=open-geo-private-evidence
OGC_EVIDENCE_S3_ACCESS_KEY_ID=
OGC_EVIDENCE_S3_SECRET_ACCESS_KEY=
OGC_EVIDENCE_S3_PREFIX=
OGC_EVIDENCE_S3_FORCE_PATH_STYLE=true
# Enable only on Vercel, whose edge overwrites x-vercel-forwarded-for.
OGC_TRUST_VERCEL_HEADERS=false
TRUST_PROXY_HEADERS=false
# Local sandbox escape hatch only. Keep false in production.
OGC_ALLOW_BENCHMARK_NETWORK=false

# Commercial rollout is fail-closed by default.
COMMERCE_MODE=disabled
FULFILLMENT_MODE=batch_24h
OGC_PRICE_CATALOG_VERSION=2026-07-10.v1
# Required explicitly before COMMERCE_MODE=live. Values are integer minor units.
OGC_PRICE_CNY_MINOR=
OGC_PRICE_USD_MINOR=
OGC_PRICE_HKD_MINOR=
OGC_PAYMENT_IDEMPOTENCY_SECRET=replace-with-a-third-independent-random-secret
OGC_EMAIL_ENCRYPTION_SECRET=replace-with-an-email-encryption-secret-of-at-least-32-characters
OGC_EMAIL_LOOKUP_SECRET=replace-with-an-independent-email-lookup-secret

# Cloudflare Turnstile. Production requires server-side verification.
TURNSTILE_REQUIRED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=
OGC_FREE_AI_DAILY_LIMIT=50

# Queue notifications are hints; PostgreSQL remains authoritative. Use
# postgres with realtime fulfillment for a persistent self-hosted polling Worker.
OGC_JOB_QUEUE_PROVIDER=noop
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_QUEUES_API_TOKEN=
CLOUDFLARE_FREE_QUEUE_ID=
CLOUDFLARE_DEEP_QUEUE_ID=
OGC_QUEUE_REQUEST_TIMEOUT_MS=10000
OGC_QUEUE_PULL_MS=30000
OGC_BATCH_FREE_REPLICAS=1
OGC_BATCH_DEEP_REPLICAS=2
OGC_DEPLOYMENT_VERSION=local

# Airwallex uses api-demo in test mode and api.airwallex.com in live mode.
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
# Optional explicit override, useful only for provider test fixtures.
AIRWALLEX_API_BASE_URL=
# One-shot retirement of pre-migration unpaid checkout resources. Keep disabled
# except for an audited protected-environment run with an explicit ISO cutoff.
OGC_LEGACY_RETIREMENT_ENABLED=false
OGC_LEGACY_RETIREMENT_CUTOFF_AT=

# Resend sends report links; use a verified custom sending domain in live mode.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Open GEO Console <reports@itheheda.online>"
RESEND_WEBHOOK_SECRET=
OGC_REPLY_TO_EMAIL="support@itheheda.online"
# Required outside the production deployment profile. All test-mode mail is
# redirected here; if it is absent, delivery fails closed before calling Resend.
OGC_TEST_EMAIL_RECIPIENT="admin@itheheda.online"
